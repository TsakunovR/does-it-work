# Скопируйте в .env и поправьте под своё окружение: cp .env.example .env
# Приоритет: переменная окружения > .env > дефолт в config.py
# Осторожно: пустая переменная (API_TESTS_BASE_URL=) не сбрасывает значение,
# а задаёт пустую строку.

# Базовый URL API (без завершающего /)
API_TESTS_BASE_URL=http://127.0.0.1:8000

# Токен авторизации
API_TESTS_API_TOKEN=secret-token

# Таймаут HTTP-запросов, секунды
API_TESTS_TIMEOUT=10

# Режим запуска: e2e — по сети против стенда | asgi — in-process через TestClient
API_TESTS_MODE=e2e
